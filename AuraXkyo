-- Toggle state variable
_G.RebirthToggle = false 

MainTab:AddToggle("RebirthToggle", {
    Title = "Auto Rebirth",
    Default = false,
    Callback = function(Value)
        _G.RebirthToggle = Value
        
        if Value then
            task.spawn(function()
                local events = game:GetService("ReplicatedStorage"):WaitForChild("Events", 5)
                local rebirthFunc = events and events:WaitForChild("Rebirth", 5)
                
                while _G.RebirthToggle do
                    if rebirthFunc and rebirthFunc:IsA("RemoteFunction") then
                        -- pcall prevents the entire script from breaking if you don't have enough stats to rebirth
                        pcall(function()
                            rebirthFunc:InvokeServer()
                        end)
                    else
                        warn("Rebirth RemoteFunction path not found!")
                        break
                    end
                    task.wait(1) -- Kept at 1 second since Rebirth validation takes longer on the server
                end
            end)
        end
    end
})

