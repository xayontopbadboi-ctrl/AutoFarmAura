-- Memory Baseline Caches
local startS1, startS2, startS3 = nil, nil, nil
local startTime = os.time()
local localPlayer = playersService.LocalPlayer

-- Tracking and Spy Loop Engine
task.spawn(function()
    while task.wait(0.4) do
        -- Update Time Tracker
        pcall(function()
            local elapsed = os.time() - startTime
            TimeLabel:SetTitle("⏳ Elapsed Time: " .. formatTime(elapsed))
        end)

        -- Local Player Tracking
        pcall(function()
            local s1Raw = findStatValue(localPlayer, {"Aura", "Auras", "AuraPower"})
            local s2Raw = findStatValue(localPlayer, {"Energy", "Mana", "Power"})
            local s3Raw = findStatValue(localPlayer, {"Rebirths", "Rebirth", "Levels", "Level"})
            
            if s1Raw > 0 and startS1 == nil then startS1 = s1Raw end
            if s2Raw > 0 and startS2 == nil then startS2 = s2Raw end
            if s3Raw > 0 and startS3 == nil then startS3 = s3Raw end
            
            local _, s1Text = formatNumber(s1Raw)
            local _, s2Text = formatNumber(s2Raw)
            local _, s3Text = formatNumber(s3Raw)
            
            local diffS1 = s1Raw - (startS1 or s1Raw)
            local diffS2 = s2Raw - (startS2 or s2Raw)
            local diffS3 = s3Raw - (startS3 or s3Raw)
            
            local _, s1GainText = formatNumber(diffS1)
            local _, s2GainText = formatNumber(diffS2)
            local _, s3GainText = formatNumber(diffS3)
            
            AuraLabel:SetTitle("✨ Aura: " .. s1Text)
            AuraLabel:SetDesc("Session Gained: +" .. s1GainText)
            
            EnergyLabel:SetTitle("⚡ Energy: " .. s2Text)
            EnergyLabel:SetDesc("Session Gained: +" .. s2GainText)
            
            RebirthsLabel:SetTitle("🔥 Rebirths: " .. s3Text)
            RebirthsLabel:SetDesc("Session Gained: +" .. s3GainText)
        end)

        -- Spy Target Player Tracking
        pcall(function()
            if SpyTarget and SpyTarget.Parent == playersService then
                local t1Raw = findStatValue(SpyTarget, {"Aura", "Auras", "AuraPower"})
                local t2Raw = findStatValue(SpyTarget, {"Energy", "Mana", "Power"})
                local t3Raw = findStatValue(SpyTarget, {"Rebirths", "Rebirth", "Levels", "Level"})
                
                local _, t1Text = formatNumber(t1Raw)
                local _, t2Text = formatNumber(t2Raw)
                local _, t3Text = formatNumber(t3Raw)
                
                SpyAura:SetTitle("✨ Target Aura: " .. t1Text)
                SpyAura:SetDesc("Tracking active")
                
                SpyEnergy:SetTitle("⚡ Target Energy: " .. t2Text)
                SpyEnergy:SetDesc("Tracking active")
                
                SpyRebirths:SetTitle("🔥 Target Rebirths: " .. t3Text)
                SpyRebirths:SetDesc("Tracking active")
            end
        end)
    end
end)

