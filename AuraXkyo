-- Formatter for Time (Converts seconds to HH:MM:SS)
local function formatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", hours, minutes, secs)
end

-- Multi-Shorthand Letter Formatter (K, M, B, T)
local function formatNumber(val)
    local num = tonumber(val)
    if not num then return 0, tostring(val) end
    
    local raw = num
    local suffixes = {"", "K", "M", "B", "T", "Qa"}
    local index = 1
    
    while math.abs(num) >= 1000 and index < #suffixes do
        num = num / 1000
        index = index + 1
    end
    
    if index > 1 then
        return raw, string.format("%.1f%s", num, suffixes[index])
    else
        return raw, string.format("%d", num)
    end
end

-- Deep Search Algorithm targeting Player objects, hidden folders, and client text labels
local function findStatValue(playerObj, names)
    if not playerObj then return 0 end
    
    -- Level 1: Standard Leaderboards and custom data directories
    local folderTargets = {"leaderstats", "MainStats", "Stats", "PlayerStats", "Data", "AuraData"}
    for _, folderName in ipairs(folderTargets) do
        local folder = playerObj:FindFirstChild(folderName)
        if folder then
            for _, name in ipairs(names) do
                local obj = folder:FindFirstChild(name) or folder:FindFirstChild(string.lower(name)) or folder:FindFirstChild(string.upper(name))
                if obj and (obj:IsA("ValueBase") or obj:IsA("RemoteEvent")) then 
                    return tonumber(obj.Value) or 0 
                end
            end
        end
    end
    
    -- Level 2: Direct attributes or Loose Objects on Player Instance
    for _, name in ipairs(names) do
        local obj = playerObj:FindFirstChild(name) or playerObj:FindFirstChild(string.lower(name))
        if obj and obj:IsA("ValueBase") then 
            return tonumber(obj.Value) or 0 
        end
        local attr = playerObj:GetAttribute(name) or playerObj:GetAttribute(string.lower(name))
        if attr and tonumber(attr) then 
            return tonumber(attr) 
        end
    end
    
    -- Level 3: Fallback extraction for Client UI elements (If scanning local player data)
    if playerObj == game:GetService("Players").LocalPlayer then
        local pGui = playerObj:FindFirstChild("PlayerGui")
        if pGui then
            for _, name in ipairs(names) do
                -- Cycle through common UI frameworks natively
                for _, gui in ipairs(pGui:GetChildren()) do
                    if gui:IsA("ScreenGui") and gui.Enabled then
                        local found = gui:FindFirstChild(name .. "Text", true) or gui:FindFirstChild(name .. "Label", true) or gui:FindFirstChild(name, true)
                        if found and found:IsA("TextLabel") then
                            local cleanNum = string.gsub(found.Text, "[%,%s%a✨⚡🔥]", "")
                            if tonumber(cleanNum) then return tonumber(cleanNum) end
                        end
                    end
                end
            end
        end
    end
    return 0
end

-- Generate list of player names for the dropdown safely
local playersService = game:GetService("Players")
local function getPlayerNames()
    local nameList = {}
    for _, p in ipairs(playersService:GetPlayers()) do
        if p ~= playersService.LocalPlayer then
            table.insert(nameList, p.Name)
        end
    end
    -- Keep dropdown running even when alone on a server
    if #nameList == 0 then table.insert(nameList, "No other players") end
    return nameList
end

