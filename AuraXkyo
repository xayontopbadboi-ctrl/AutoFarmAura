-- Touch Dragging Logic
local dragging, dragInput, dragStart, startPos
local dragSpeed = 0.05 -- Faster tween response for mobile touch feedback

local function update(input)
    local delta = input.Position - dragStart
    local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    TweenService:Create(TouchButton, TweenInfo.new(dragSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos}):Play()
end

TouchButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = TouchButton.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TouchButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- Tap Trigger Event (Fires Fluent Menu Hotkey)
local dragThreshold = 10 -- Higher threshold for touch variance to prevent accidental drag cancels
TouchButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        if dragStart then
            local endPos = input.Position
            local distance = (Vector2.new(endPos.X, endPos.Y) - Vector2.new(dragStart.X, dragStart.Y)).Magnitude
            
            if distance < dragThreshold then
                -- Visual press feedback
                TweenService:Create(TouchButton, TweenInfo.new(0.1), {BackgroundTransparency = 0.5}):Play()
                
                -- Triggers LeftControl Keybind for the Library
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
                task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
                
                task.wait(0.08)
                TweenService:Create(TouchButton, TweenInfo.new(0.1), {BackgroundTransparency = 0.2}):Play()
            end
        end
    end
end)
