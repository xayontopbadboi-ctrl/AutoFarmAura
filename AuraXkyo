        -- Update Time Tracker
        pcall(function()
            local elapsed = os.time() - startTime
            TimeLabel:SetTitle("⏳ Elapsed Time: " .. formatTime(elapsed))
        end)

        -- Local Player Tracking
        pcall(function()
            local s1Raw = findStatValue(localPlayer, {"Aura", "Auras", "AuraPower"})
            local s2Raw = findStatValue(localPlayer, {"Energy", "Mana", "Power"})
            local s3Raw = findStatValue(localPlayer, {"Rebirths", "Rebirth", "Levels", "Level"})
            
